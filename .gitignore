cat > .gitignore << 'EOF'
# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE / Editor
.vscode/
.idea/
*.code-workspace

# Temporary files
*.tmp
*.log
*.bak

# Azure / Terraform
*.tfstate
*.tfstate.backup
.terraform/

# Splunk artifacts
*.spl.bak
dispatch/
fishbucket/

# Sensitive files — never commit
*.env
secrets/
credentials/
*.pem
*.key
*.pfx

# OS thumbnails
Thumbs.db
EOF
